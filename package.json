{
  "name": "@nnilky/structo",
  "description": "A library for serializing and deserializing binary content",
  "keywords": [
    "binary",
    "library",
    "utility",
    "web",
    "node"
  ],
  "license": "ISC",
  "version": "1.0.6",
  "author": "Ben Brady",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ben-Brady/structo-ts.git"
  },
  "readme": "README.md",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./index.js": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "./dist/**/*.d.ts",
    "./dist/**/*.js.map",
    "./dist/**/*.js"
  ],
  "scripts": {
    "build": "tsc",
    "prepublish": "tsc",
    "check": "tsc --noEmit",
    "test": "bun test src --only-failures --coverage"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "bun-types": "^1.3.14",
    "jest": "^30.4.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.13.1"
}
